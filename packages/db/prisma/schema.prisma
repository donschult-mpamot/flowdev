// FlowDev Prisma schema
//
// Models landed so far:
//   AuditLog                                 → Story 1.7 (2026-04-30)
//   User / Account / Session / VerificationToken
//   + Role / UserStatus enums                → Story 1.2 (2026-05-05)
// Migrations now drive the schema (`prisma migrate dev/deploy`).
//
// Subsequent stories add models incrementally:
//   App                                      → Story 2.1
//   Connector / ConnectorCredential          → Stories 2.4–2.5
//   WebhookEventRaw                          → Story 2.13
//   HealthCheckResult                        → Story 2.12
//   MetricSnapshot / Hourly / Daily          → Stories 3.1–3.4
//   CostRecord / FxRate                      → Stories 4.1–4.2
//   ActivityEvent / IntegrationCallEvent /
//     CustomMetricEvent                      → Story 5.1
//   ResourceSnapshot                         → Story 3.x
//   EmailEvent                               → Story 6.1
//   AlertRule / AlertEvent                   → Stories 8.1–8.3
//   UserAppAssignment / Setting              → Stories 1.6 / 4.10

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// FlowDev RBAC roles (FR64). VIEWER is deferred to v2.
enum Role {
  ADMIN
  MANAGER
  DEVELOPER
}

// User lifecycle. Default INVITED; flips to ACTIVE on first successful sign-in
// (Story 1.5 wires the transition). REMOVED is a soft-delete sentinel set when
// ADMIN removes a user — the row is retained so historical audit log foreign
// references still resolve.
enum UserStatus {
  INVITED
  ACTIVE
  REMOVED
}

// Auth.js v5 + FlowDev User. Auth.js's @auth/prisma-adapter requires the
// id/email/emailVerified/image columns and the accounts/sessions relations.
// FlowDev extends with passwordHash (credentials fallback only — null for
// SSO-only users), status, role, and removedAt.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  passwordHash  String?
  status        UserStatus @default(INVITED)
  role          Role       @default(DEVELOPER)
  removedAt     DateTime?

  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([role])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Append-only audit trail (FR67, NFR-S6).
// Writers MUST go through `appendAudit()` from `@flowdev/shared`; direct
// `prisma.auditLog.{update,updateMany,delete,deleteMany,upsert}` calls are
// blocked at lint time (eslint.config.mjs no-restricted-syntax) AND at the
// Postgres layer (REVOKE in the 1_7_audit_log migration).
model AuditLog {
  id           BigInt   @id @default(autoincrement())
  // TIMESTAMPTZ — audit logs need unambiguous instants. Cross-region readers
  // see the same moment without relying on session-level timezone config.
  occurredAt   DateTime @default(now()) @db.Timestamptz(3)
  actorId      String?
  appId        String?
  connectorId  String?
  credentialId String?
  op           String
  kvKeyVersion String?
  context      Json?

  @@index([appId, occurredAt(sort: Desc)])
  @@index([actorId, occurredAt(sort: Desc)])
  @@index([op, occurredAt(sort: Desc)])
  @@map("audit_logs")
}
