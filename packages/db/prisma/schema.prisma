// FlowDev Prisma schema
//
// Story 1.7 (2026-04-30) added AuditLog — the first real model — and flipped
// the project from `prisma db push` to `prisma migrate dev/deploy`. Subsequent
// stories add models incrementally:
//   User / Account / Session   → Story 1.2 (@auth/prisma-adapter)
//   App                         → Story 2.1
//   Connector / ConnectorCredential → Stories 2.4–2.5
//   WebhookEventRaw             → Story 2.13
//   HealthCheckResult           → Story 2.12
//   MetricSnapshot / Hourly / Daily aggregates → Stories 3.1–3.4
//   CostRecord / FxRate         → Stories 4.1–4.2
//   ActivityEvent / IntegrationCallEvent / CustomMetricEvent → Story 5.1
//   ResourceSnapshot            → Story 3.x
//   EmailEvent                  → Story 6.1
//   AlertRule / AlertEvent      → Stories 8.1–8.3
//   UserAppAssignment / Setting → Stories 1.6 / 4.10

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Append-only audit trail (FR67, NFR-S6).
// Writers MUST go through `appendAudit()` from `@flowdev/shared`; direct
// `prisma.auditLog.{update,updateMany,delete,deleteMany,upsert}` calls are
// blocked at lint time (eslint.config.mjs no-restricted-syntax) AND at the
// Postgres layer (REVOKE in the 1_7_audit_log migration).
model AuditLog {
  id           BigInt   @id @default(autoincrement())
  // TIMESTAMPTZ — audit logs need unambiguous instants. Cross-region readers
  // see the same moment without relying on session-level timezone config.
  occurredAt   DateTime @default(now()) @db.Timestamptz(3)
  actorId      String?
  appId        String?
  connectorId  String?
  credentialId String?
  op           String
  kvKeyVersion String?
  context      Json?

  @@index([appId, occurredAt(sort: Desc)])
  @@index([actorId, occurredAt(sort: Desc)])
  @@index([op, occurredAt(sort: Desc)])
  @@map("audit_logs")
}
