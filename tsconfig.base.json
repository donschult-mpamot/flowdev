{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@flowdev/web": ["apps/web/src"],
      "@flowdev/web/*": ["apps/web/src/*"],
      "@flowdev/worker": ["apps/worker/src"],
      "@flowdev/worker/*": ["apps/worker/src/*"],
      "@flowdev/jobs": ["apps/jobs/src"],
      "@flowdev/jobs/*": ["apps/jobs/src/*"],
      "@flowdev/connectors": ["packages/connectors/src"],
      "@flowdev/connectors/*": ["packages/connectors/src/*"],
      "@flowdev/db": ["packages/db/src"],
      "@flowdev/db/*": ["packages/db/src/*"],
      "@flowdev/shared": ["packages/shared/src"],
      "@flowdev/shared/*": ["packages/shared/src/*"]
    }
  }
}
