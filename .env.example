# FlowDev — local environment template
# Copy to .env (which is gitignored) and adjust as needed.

# Postgres (matches docker-compose.yml flowdev-postgres service)
# Host port 5433 — avoids collision with a Windows-installed Postgres that
# some dev boxes have pre-installed. Container internally still uses 5432.
POSTGRES_USER=flowdev
POSTGRES_PASSWORD=flowdev
POSTGRES_DB=flowdev

# Prisma datasource — read by packages/db
DATABASE_URL=postgresql://flowdev:flowdev@localhost:5433/flowdev?schema=public

# Next.js
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js (Story 1.2 — leave blank in 1.1)
# AUTH_SECRET=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
# CREDENTIALS_FALLBACK_ENABLED=true
