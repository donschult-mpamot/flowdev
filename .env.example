# FlowDev — local environment template
# Copy to .env (which is gitignored) and adjust as needed.

# Postgres (matches docker-compose.yml flowdev-postgres service)
# Host port 5433 — avoids collision with a Windows-installed Postgres that
# some dev boxes have pre-installed. Container internally still uses 5432.
POSTGRES_USER=flowdev
POSTGRES_PASSWORD=flowdev
POSTGRES_DB=flowdev

# Prisma datasource — read by packages/db
DATABASE_URL=postgresql://flowdev:flowdev@localhost:5433/flowdev?schema=public

# Next.js
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js v5 (Story 1.2)
# AUTH_SECRET — 32+ char random string. Generate with: openssl rand -base64 32
# AZURE_AD_* — from your Azure Entra ID app registration (Story 1.2 ships
#   stubs; live SSO acceptance in staging once these are populated).
# CREDENTIALS_FALLBACK_ENABLED — set to "true" to enable the credentials
#   provider in production. In dev (NODE_ENV !== "production") it's always on.
AUTH_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
CREDENTIALS_FALLBACK_ENABLED=true

# Dev admin seed (consumed by `npm run db:seed`). No-op when unset.
DEV_ADMIN_EMAIL=
DEV_ADMIN_PASSWORD=
